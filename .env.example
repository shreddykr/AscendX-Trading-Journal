# Copy this file to ".env" and fill in values to enable real password-reset emails.
# If these are left unset, reset links are printed to the server console window instead.

# --- Email (password reset) ---
# Example for a Gmail account using an App Password (https://myaccount.google.com/apppasswords):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=youraddress@gmail.com
# SMTP_PASS=your_16_char_app_password
# SMTP_FROM=AscendX Journal <youraddress@gmail.com>

# --- Optional security overrides ---
# A fixed 64-character hex key used to encrypt all journal files. If unset, a random
# key is generated once and stored in data/secret.key. Set this to keep the same key
# across machines (back it up — losing it makes encrypted journals unreadable).
# ASCENDX_MASTER_KEY=

# Secret used to sign login session cookies. Defaults to the master key if unset.
# SESSION_SECRET=

# Port the server listens on (default 8082).
# PORT=8082
